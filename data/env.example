# Qdrant
QDRANT_URL=http://localhost:6333 # Update if your Qdrant instance is running elsewhere
QDRANT_API_KEY=your_qdrant_api_key_here

# Collection name (optional, default: star_learners_kb)
QDRANT_COLLECTION=star_learners_kb # Update if you want to use a different collection name

# Gemini model overrides (optional, defaults shown)
GEMINI_TEXT_EMBED_MODEL=gemini-embedding-001
GEMINI_IMAGE_EMBED_MODEL=multimodalembedding@001
GEMINI_CAPTION_MODEL=gemini-2.5-flash

# Vertex AI (required for multimodalembedding@001)
GCP_PROJECT=your_gcp_project_id_here
GCP_LOCATION=us-central1
